{
  "mouseover": [
    {
      "selector": ".site-brand",
      "text": ["欢迎来到 Jellyfish 的小站。"]
    },
    {
      "selector": ".site-menu a",
      "text": ["要去看看「{text}」吗？"]
    },
    {
      "selector": "[data-search-input], .site-search input",
      "text": ["在找什么东西呢，需要帮忙吗？"]
    },
    {
      "selector": ".post-card h2 a, .home-portal a",
      "text": ["要看看「{text}」么？"]
    },
    {
      "selector": ".primary-button, .ghost-button",
      "text": ["这个按钮会带你去「{text}」。"]
    },
    {
      "selector": ".random-quote, [data-quote-next]",
      "text": ["想换一句话？我也喜欢这种小小的随机。"]
    },
    {
      "selector": ".home-stats-panel",
      "text": ["数字在这里排排坐，记录这个小站的脚印。"]
    }
  ],
  "click": [
    {
      "selector": "#landlord #live2d",
      "text": ["不要动手动脚的！", "真…真的是不知羞耻！", "Hentai！", "再摸的话我可要报警了！⌇●﹏●⌇", "110吗，这里有个变态一直在摸我(ó﹏ò｡)"]
    }
  ]
}
