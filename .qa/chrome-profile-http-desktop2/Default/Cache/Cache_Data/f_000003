}

.post-single-header {
  margin-bottom: 20px;
}

.post-single-header .post-category {
  display: inline-flex;
  margin-bottom: 14px;
}

.post-single-header h1 {
  margin: 0 0 10px;
  font-size: clamp(30px, 4vw, 46px);
  line-height: 1.18;
  letter-spacing: 0;
  text-wrap: balance;
}

.post-content {
  font-size: 17px;
  line-height: 1.9;
}

.post-content > p:first-child {
  font-size: 1.03em;
}

.post-content hr {
  border: 0;
  height: 1px;
  margin: 2em 0;
  background: linear-gradient(90deg, transparent, rgba(40,120,107,.32), transparent);
}

.post-toc {
  margin: 22px 0 8px;
  padding: 12px 14px;
  border: 1px solid rgba(40,120,107,.14);
  border-radius: var(--radius);
