}

.embedded-game-page[data-game-page="server-survival"] .embedded-game-frame-wrap {
  box-shadow: var(--shadow), 0 0 36px rgba(1,205,253,.18);
}

.embedded-game-page[data-game-page="vimmaster"] .embedded-game-frame-wrap {
  box-shadow: var(--shadow), 0 0 36px rgba(143,101,255,.18);
}

.embedded-game-frame {
  display: block;
  width: 100%;
  height: min(78vh, 860px);
  min-height: 620px;
  border: 0;
  background: #0f1518;
}

.ghost-button {
  color: var(--muted);
  border-color: var(--line);
  background: rgba(255,255,255,.45);
  box-shadow: none;
}

main article.mw8,
main article.mw7,
main article.pa3 {
  max-width: 780px;
}

main article.mw8 {
  border: 1px solid rgba(255,255,255,.72);
  border-radius: var(--radius);
  background: rgba(255,255,255,.72);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
  margin-top: 24px;
}

.post-single {
  padding-top: 30px;
  position: relative;
  overflow: hidden;
}

.post-single::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 4px;
  background: linear-gradient(90deg, var(--accent), var(--vapor-cyan), var(--vapor-pink));
