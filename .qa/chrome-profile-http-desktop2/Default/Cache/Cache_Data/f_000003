  transform: rotate(var(--note-rotate, 0deg));
  border-bottom: 0;
}

.board-note:hover,
.board-note:focus-visible {
  transform: translateY(-4px) rotate(var(--note-rotate, 0deg));
  box-shadow: 0 24px 52px rgba(70, 96, 150, .18);
}

.board-note span {
  width: fit-content;
  padding: 3px 9px;
  border: 1px solid rgba(132, 166, 232, .34);
  border-radius: 999px;
  color: #5171b4;
  font-size: 12px;
  font-weight: 900;
}

.board-note strong {
  color: #28498c;
  font-size: clamp(17px, 1.6vw, 21px);
  line-height: 1.3;
}

.board-note em {
  color: #637ca9;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
}

.board-note:nth-child(1) { left: 6%; top: 14%; --note-rotate: -2deg; }
.board-note:nth-child(2) { left: 34%; top: 6%; --note-rotate: 2deg; }
.board-note:nth-child(3) { left: 58%; top: 8%; --note-rotate: -3deg; }
.board-note:nth-child(4) { right: 5%; top: 12%; --note-rotate: 3deg; }
.board-note:nth-child(5) { left: 30%; bottom: 14%; --note-rotate: -2deg; }
.board-note:nth-child(6) { left: 54%; bottom: 8%; --note-rotate: 4deg; }

.note-blue { background: linear-gradient(135deg, #eef5ff, #dfeaff); }
.note-green { background: linear-gradient(135deg, #ecfff6, #d9f3e7); }
.note-white { background: linear-gradient(135deg, #ffffff, #f4f7ff); }
.note-pink { background: linear-gradient(135deg, #fff0f6, #ffe1ec); }
.note-lilac { background: linear-gradient(135deg, #f4f0ff, #e8e0ff); }
.note-sky { background: linear-gradient(135deg, #effaff, #dcefff); }

.home-floating-tools {
