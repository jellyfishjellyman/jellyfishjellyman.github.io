/* Central theme layer: keeps older component-specific art while making every UI surface follow day/night tokens. */
.post-card,
.module-card,
.game-card,
.feature-card,
.resource-tag,
.link-item,
.home-now,
.module-stats span,
.resource-dialog,
.game-panel,
.board-wrap,
.game-tutorial,
main article.mw8,
.post-toc,
.post-neighbors a,
.not-found-panel,
#backToTop,
.music-panel {
  border-color: var(--panel-border);
  background-color: var(--panel);
  color: var(--text);
}

.home-now,
.feature-strip .feature-card,
.module-stats span,
.game-tutorial,
.not-found-panel,
.post-neighbors a {
  background:
    linear-gradient(135deg, var(--panel-strong), var(--panel)),
    radial-gradient(460px circle at 8% 0%, color-mix(in srgb, var(--vapor-cyan) 16%, transparent), transparent 62%),
    radial-gradient(460px circle at 100% 36%, color-mix(in srgb, var(--vapor-pink) 14%, transparent), transparent 62%);
}

.resource-tag,
.link-item,
.home-now-list span,
.tool-more summary,
.ghost-button,
.tile-2048,
.mine-cell[data-state="open"],
code {
  background: var(--field-bg);
  color: var(--text);
}

.link-item:hover,
.link-item:focus-visible,
.resource-tag:hover,
.resource-tag:focus-visible,
.resource-tag.is-active,
.tool-more summary:hover,
.tool-more[open] summary {
  background: var(--panel-hover);
  box-shadow: var(--shadow-soft), var(--glow);
}

.game-panel,
.board-wrap,
main article.mw8,
.music-panel,
#backToTop {
  background: var(--panel);
  box-shadow: var(--shadow);
}

.board-2048,
.mine-board,
.memory-board,
.score-row div {
  border: 1px solid var(--chip-border);
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--text) 9%, transparent), color-mix(in srgb, var(--accent) 9%, transparent)),
    var(--field-bg);
}

.mine-cell {
  border-color: var(--panel-border);
  background:
    radial-gradient(circle at 28% 22%, color-mix(in srgb, var(--panel-strong) 90%, transparent), transparent 28%),
    linear-gradient(135deg, color-mix(in srgb, var(--dream-mint) 72%, var(--panel)), var(--panel));
  color: var(--text);
}

.mine-cell[data-state="open"] {
  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--text) 7%, transparent);
}

.dino-canvas {
  border-color: var(--panel-border);
  background: var(--panel-strong);
}

.memory-card[data-state="open"],
.memory-card[data-state="matched"] {
  background:
    radial-gradient(circle at 32% 22%, color-mix(in srgb, var(--panel-strong) 80%, transparent), transparent 28%),
    linear-gradient(135deg, color-mix(in srgb, var(--dream-moon) 52%, var(--panel)), color-mix(in srgb, var(--vapor-pink) 14%, var(--panel)));
}

.post-content,
.post-summary,
.module-copy,
.game-message,
.post-toc,
blockquote,
.callout {
  color: var(--subtle-text);
}

blockquote,
.callout,
.post-toc {
  background: color-mix(in srgb, var(--accent) 9%, var(--panel));
}

#musicToggle {
  color: var(--text);
  background:
    radial-gradient(circle at 35% 28%, color-mix(in srgb, var(--panel-strong) 90%, transparent), transparent 28%),
    linear-gradient(135deg, color-mix(in srgb, var(--vapor-cyan) 30%, transparent), color-mix(in srgb, var(--vapor-pink) 24%, transparent));
  box-shadow: inset 0 0 0 1px var(--panel-border);
}

:root[data-theme="night"] .home-hero::after {
  background: linear-gradient(180deg, transparent, var(--page-wash));
}

:root[data-theme="night"] .home-grid .post-card:first-child,
:root[data-theme="night"] .game-cover.is-console,
:root[data-theme="night"] .game-cover.is-memory,
:root[data-theme="night"] .embedded-game-frame-wrap,
:root[data-theme="night"] .embedded-game-frame,
:root[data-theme="night"] pre {
  background-color: var(--dark-panel);
  color: var(--dark-panel-text);
}

:root[data-theme="night"] .site-footer {
  background:
    radial-gradient(700px circle at 18% 0%, rgba(49,214,201,.18), transparent 52%),
    radial-gradient(600px circle at 80% 80%, rgba(233,93,137,.16), transparent 52%),
    linear-gradient(135deg, #07100f, #121526);
}

.reveal-on-scroll {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity .65s ease, transform .65s ease;
}

.reveal-on-scroll.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.module-intro.reveal-on-scroll,
.post-card.reveal-on-scroll,
.post-group.reveal-on-scroll,
.module-card.reveal-on-scroll,
.game-card.reveal-on-scroll,
.feature-card.reveal-on-scroll,
.link-item.reveal-on-scroll {
  opacity: 1;
  transform: translateY(0);
}

.post-card.reveal-on-scroll,
.module-card.reveal-on-scroll,
.game-card.reveal-on-scroll,
.feature-card.reveal-on-scroll {
  transform: perspective(900px) rotateX(var(--tilt-y, 0deg)) rotateY(var(--tilt-x, 0deg)) translateY(0);
}

