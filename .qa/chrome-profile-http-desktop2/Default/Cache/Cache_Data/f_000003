  transform: translateY(-2px) scale(1.015);
}

.memory-card[data-state="matched"] {
  opacity: .82;
  box-shadow: 0 0 0 2px rgba(40,120,107,.22), 0 12px 28px rgba(44,42,35,.1);
}

.game-message {
  min-height: 1.8em;
  margin: 14px 0 0;
  color: var(--muted);
  text-align: center;
}

.embedded-game-page {
