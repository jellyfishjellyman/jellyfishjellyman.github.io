}

.post-neighbors span {
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 900;
}

.post-neighbors strong {
  line-height: 1.45;
}

pre,
code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}

pre {
  position: relative;
  padding: 42px 16px 16px;
  border-radius: var(--radius);
  overflow: auto;
  background: #111814;
  color: #eef4ef;
  border: 1px solid rgba(255,255,255,.08);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
}

.copy-code-button {
  position: absolute;
  top: 10px;
  right: 12px;
  z-index: 2;
  min-height: 28px;
  padding: 4px 9px;
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 6px;
  background: rgba(255,255,255,.08);
  color: rgba(238,244,239,.78);
  font-size: 12px;
  font-weight: 800;
}

.copy-code-button:hover,
.copy-code-button:focus-visible {
  background: rgba(255,255,255,.15);
  color: #fff;
}

pre::before {
  content: "";
  position: absolute;
  left: 16px;
  top: 15px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ff6b7a;
  box-shadow: 18px 0 #d8b64c, 36px 0 #31d6c9;
}

code {
  background: rgba(23, 32, 27, .07);
  padding: 0.12em 0.35em;
  border-radius: 6px;
}

blockquote {
  margin: 1.2em 0;
  padding: 0.8em 1em;
  border-left: 4px solid rgba(40,120,107,.5);
  background:
    linear-gradient(90deg, rgba(40,120,107,.1), rgba(255,255,255,.36));
  border-radius: var(--radius);
}

.callout {
  margin: 1.2em 0;
  padding: 0.85em 1em;
  border: 1px solid rgba(40,120,107,.18);
  border-left: 4px solid rgba(40,120,107,.58);
  border-radius: var(--radius);
  background: rgba(40,120,107,.08);
}

.callout p {
  margin: 0.35em 0;
}

article img {
  border-radius: var(--radius);
  box-shadow: 0 18px 60px rgba(0,0,0,.14);
  cursor: var(--paw-cursor);
}

.image-lightbox {
  position: fixed;
  inset: 0;
  z-index: 2200;
  display: none;
  place-items: center;
  padding: 24px;
  background: rgba(10,16,14,.72);
  backdrop-filter: blur(16px);
}

.image-lightbox.is-open {
  display: grid;
}

.image-lightbox img {
  max-width: min(1100px, 94vw);
  max-height: 86vh;
  object-fit: contain;
  border-radius: var(--radius);
  box-shadow: 0 30px 90px rgba(0,0,0,.34);
}

.image-lightbox-close {
  position: fixed;
  right: 20px;
  top: 18px;
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.22);
  border-radius: var(--radius);
  background: rgba(255,255,255,.12);
  color: #fff;
  font-size: 28px;
  line-height: 1;
}

.not-found-page {
  width: min(900px, calc(100% - 32px));
  min-height: 62vh;
  margin: 0 auto;
  display: grid;
  place-items: center;
  padding: 54px 0 90px;
}

.not-found-panel {
  width: 100%;
  padding: clamp(24px, 6vw, 52px);
  border: 1px solid rgba(255,255,255,.72);
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, rgba(255,255,255,.84), rgba(255,255,255,.58)),
    radial-gradient(520px circle at 0% 0%, rgba(255,113,206,.16), transparent 62%),
    radial-gradient(520px circle at 100% 30%, rgba(1,205,253,.16), transparent 62%);
  box-shadow: var(--shadow);
  text-align: center;
}

.not-found-panel h1 {
  margin: 0;
  font-size: clamp(34px, 7vw, 72px);
}

.not-found-panel p:not(.eyebrow) {
  color: var(--muted);
}

.not-found-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-top: 22px;
}

.site-footer {
  position: relative;
  margin-top: 70px;
  padding: 34px 16px;
  color: rgba(247, 251, 244, .78);
  background:
    radial-gradient(700px circle at 18% 0%, rgba(49,214,201,.18), transparent 52%),
    radial-gradient(600px circle at 80% 80%, rgba(233,93,137,.16), transparent 52%),
    linear-gradient(135deg, #081314, #171827);
}

.site-footer::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: .2;
  background-image:
    linear-gradient(rgba(141,242,229,.18) 1px, transparent 1px),
    linear-gradient(90deg, rgba(141,242,229,.12) 1px, transparent 1px);
  background-size: 46px 46px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,.65), transparent);
}

.site-footer-inner {
  position: relative;
  width: min(1120px, calc(100% - 28px));
  margin: 0 auto;
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 24px;
}

.footer-kicker {
  margin: 0 0 8px;
  color: #8df2e5;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.footer-brand {
  color: #f7fbf4;
  border: 0;
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 900;
}

.footer-copy {
  margin: 8px 0 0;
  color: rgba(247,251,244,.62);
}

.footer-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
  color: rgba(247,251,244,.58);
  font-size: 13px;
}

.footer-meta span {
  min-height: 30px;
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--radius);
  background: rgba(255,255,255,.06);
}

#backToTop {
  position: fixed;
  right: 16px;
  width: 44px;
  height: 44px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.62);
  background: rgba(255,250,242,.78);
  color: var(--text);
  backdrop-filter: blur(12px);
  display: grid;
  place-items: center;
  box-shadow: 0 12px 34px rgba(44,42,35,.14);
  z-index: 1000;
}

#backToTop {
  bottom: 16px;
  opacity: 0;
  transform: translateY(10px);
  pointer-events: none;
  transition: opacity .2s ease, transform .2s ease;
}

#backToTop.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.music-panel {
  position: fixed;
  right: 16px;
  bottom: 70px;
  z-index: 1000;
  width: 56px;
  min-height: 54px;
  display: grid;
  grid-template-columns: 38px 1fr;
  gap: 0;
  align-items: center;
  padding: 8px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.62);
  border-radius: var(--radius);
  background: rgba(255,250,242,.78);
  color: var(--text);
  backdrop-filter: blur(16px);
  box-shadow: 0 16px 42px rgba(44,42,35,.16), 0 0 32px rgba(1,205,253,.1);
  transition: width .24s ease, box-shadow .24s ease, border-color .24s ease;
}

#musicToggle {
  width: 38px;
  height: 38px;
  border: 0;
  border-radius: 50%;
  display: grid;
  place-items: center;
  color: #17201b;
  background:
    radial-gradient(circle at 35% 28%, rgba(255,255,255,.9), transparent 28%),
    linear-gradient(135deg, rgba(1,205,253,.34), rgba(255,113,206,.26));
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.8);
  font-size: 17px;
}

.music-copy {
  min-width: 0;
  width: 0;
  opacity: 0;
  overflow: hidden;
  white-space: nowrap;
  transition: opacity .18s ease, width .24s ease;
}

.music-title {
  display: block;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--accent);
}

.music-status {
  display: block;
  margin-top: 1px;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.2;
}

.music-bars {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 3px;
  height: 18px;
  align-items: end;
  opacity: 0;
  transition: opacity .2s ease;
}

.music-bars span {
  display: block;
  height: 22%;
  border-radius: 999px;
  background: linear-gradient(to top, var(--vapor-cyan), var(--vapor-pink));
  opacity: .44;
  transform-origin: bottom;
}

.music-panel.is-playing {
  border-color: rgba(1,205,253,.4);
  box-shadow: 0 18px 48px rgba(44,42,35,.18), 0 0 44px rgba(255,113,206,.17);
}

.music-panel:hover,
.music-panel:focus-within,
.music-panel.is-playing {
  width: 188px;
  gap: 10px;
}

.music-panel:hover .music-copy,
.music-panel:focus-within .music-copy,
.music-panel.is-playing .music-copy {
  width: 116px;
  opacity: 1;
}

.music-panel:hover .music-bars,
.music-panel:focus-within .music-bars,
.music-panel.is-playing .music-bars {
  opacity: 1;
}

.music-panel.is-playing #musicToggle {
  color: #fffaf2;
  background: linear-gradient(135deg, #28786b, #8f65ff 55%, #ff71ce);
}

.music-panel.is-playing .music-bars span {
  opacity: .9;
  animation: equalize 1.1s ease-in-out infinite;
  animation-delay: calc(var(--bar-index) * -82ms);
}

@keyframes equalize {
  0%, 100% { height: 22%; }
  35% { height: 95%; }
  70% { height: 48%; }
}

