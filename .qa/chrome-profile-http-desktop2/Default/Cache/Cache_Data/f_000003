  overflow: hidden;
  border: 1px solid rgba(154, 184, 238, .52);
  border-radius: 8px;
  background: rgba(255, 255, 255, .86);
  color: #29457f;
  box-shadow: 0 18px 48px rgba(70, 96, 150, .14);
