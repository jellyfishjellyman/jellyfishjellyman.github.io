    linear-gradient(135deg, rgba(255,255,255,.84), rgba(255,255,255,.58)),
    radial-gradient(520px circle at 0% 0%, rgba(1,205,253,.14), transparent 62%),
    radial-gradient(520px circle at 100% 40%, rgba(255,113,206,.12), transparent 62%);
