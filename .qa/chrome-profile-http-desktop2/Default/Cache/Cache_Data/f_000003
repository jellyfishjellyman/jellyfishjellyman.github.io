    padding: 8px;
  }

  .music-panel {
    right: 10px;
    bottom: 12px;
  }

  .post-summary {
    padding-right: 12px;
  }

  #backToTop {
    right: 10px;
    bottom: 74px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: .01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: .01ms !important;
  }

  .home-hero-canvas {
    display: none;
  }

  .home-orb,
  .home-orb::after,
  .home-orb-core {
    transform: none;
  }
}
