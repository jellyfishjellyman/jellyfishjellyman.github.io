.search-results {
  display: grid;
  gap: 10px;
  margin-top: 14px;
}

.search-result,
.search-empty {
  display: grid;
  gap: 4px;
  padding: 10px;
  border: 1px solid var(--chip-border);
  border-radius: var(--radius);
  background: var(--field-bg);
}

.search-result {
  color: var(--text);
}

.search-result strong {
  font-size: 1rem;
}

.search-result span,
.search-empty {
  color: var(--muted);
  font-size: 13px;
}

.random-quote {
  margin: 12px 0;
  padding: 12px;
  border-left-width: 3px;
}

.random-quote p {
  margin: 0;
  color: var(--text);
  font-size: 1.02rem;
  font-weight: 750;
}

.random-quote cite {
  display: block;
  margin-top: 8px;
  color: var(--muted);
  font-size: 13px;
  font-style: normal;
}

.site-stats {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
  margin-top: 12px;
}

.site-stats span {
  min-width: 0;
  padding: 9px 10px;
  border: 1px solid var(--chip-border);
  border-radius: var(--radius);
  background: var(--field-bg);
  color: var(--muted);
  font-size: 13px;
}

.site-stats strong {
  display: block;
  color: var(--text);
  font-size: 1rem;
  line-height: 1.35;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.search-page-panel,
.guestbook-board,
.guestbook-plan {
  width: min(980px, calc(100% - 32px));
  margin-inline: auto;
}

.search-page-panel {
  padding: clamp(18px, 4vw, 28px);
}

.guestbook-board {
  min-height: 330px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  align-items: center;
  padding: clamp(18px, 4vw, 30px);
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, var(--panel-strong), var(--panel)),
    linear-gradient(rgba(40, 120, 107, .06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(40, 120, 107, .06) 1px, transparent 1px);
  background-size: auto, 36px 36px, 36px 36px;
  box-shadow: var(--shadow-soft);
}

.guest-note {
  min-height: 190px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12px;
  padding: 18px;
  border: 1px solid var(--chip-border);
  border-radius: var(--radius);
  background: var(--field-bg);
  color: var(--muted);
  box-shadow: 0 16px 42px rgba(44, 42, 35, .1);
}

.guest-note:nth-child(2) {
  transform: translateY(-18px) rotate(1.2deg);
}

.guest-note:nth-child(3) {
  transform: translateY(14px) rotate(-1deg);
}

.guest-note span {
  color: var(--accent-2);
  font-size: 13px;
  font-weight: 900;
}

.guest-note strong {
  color: var(--text);
  font-size: clamp(18px, 2.4vw, 24px);
  line-height: 1.35;
}

.guest-note em {
  width: fit-content;
  padding: 4px 9px;
  border: 1px solid var(--chip-border);
  border-radius: var(--radius);
  background: var(--chip-bg);
  color: var(--accent);
  font-size: 12px;
  font-style: normal;
  font-weight: 800;
}

.note-blue {
  background: color-mix(in srgb, var(--vapor-cyan) 10%, var(--field-bg));
}

.note-green {
  background: color-mix(in srgb, var(--dream-mint) 36%, var(--field-bg));
}

.note-pink {
  background: color-mix(in srgb, var(--vapor-pink) 10%, var(--field-bg));
}

.guestbook-plan {
  margin-top: 18px;
  padding: clamp(18px, 4vw, 26px);
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, var(--panel-strong), var(--panel)),
    radial-gradient(360px circle at 12% 0%, color-mix(in srgb, var(--vapor-cyan) 14%, transparent), transparent 62%);
  box-shadow: var(--shadow-soft);
}

.guestbook-plan h2 {
  margin: 0 0 8px;
}

.guestbook-plan p {
  margin: 0;
  color: var(--muted);
}

.feature-strip .feature-card {
  background:
    linear-gradient(180deg, var(--panel-strong), var(--panel)),
    radial-gradient(320px circle at 20% 0%, rgba(49,214,201,.16), transparent 54%);
}

.feature-card {
  min-height: 152px;
  padding: 18px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: var(--text);
  border-bottom: 0;
}

.feature-card span {
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.feature-card strong {
  display: block;
  margin-top: 8px;
  font-size: 1.28rem;
}

.feature-card p {
  color: var(--muted);
  font-size: 14px;
}

.module-page {
  padding: 44px 0 90px;
}

.module-intro {
  max-width: 760px;
  margin: 0 auto 28px;
  text-align: center;
}

.module-intro-panel,
.module-intro {
  position: relative;
}

.module-intro h1 {
  margin: 0;
  font-size: clamp(34px, 7vw, 72px);
}

.module-copy {
  color: var(--muted);
}

.module-stats {
  max-width: 820px;
  margin: 20px auto 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
}

.module-stats span {
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 12px;
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background:
    linear-gradient(180deg, var(--panel-strong), var(--panel-soft)),
    radial-gradient(220px circle at 12% 0%, rgba(49,214,201,.14), transparent 60%);
  color: var(--muted);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(14px);
  font-size: 13px;
}

.module-stats strong {
  color: var(--text);
  font-size: 15px;
}

.resource-shell {
  display: grid;
  gap: 22px;
}

.resource-tags {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}

.resource-tag {
  position: relative;
  min-height: 132px;
  padding: 14px;
  display: grid;
  grid-template-columns: 38px 1fr;
  grid-template-rows: 1fr auto;
  gap: 10px 12px;
  align-items: start;
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background: var(--panel-soft);
  box-shadow: var(--shadow-soft);
  color: var(--text);
  text-align: left;
  cursor: var(--paw-cursor);
  transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
}

.resource-tag:hover,
.resource-tag:focus-visible,
.resource-tag.is-active {
  transform: translateY(-4px);
  border-color: rgba(1,205,253,.42);
  background: var(--panel-hover);
  box-shadow: var(--shadow), var(--glow);
}

.resource-tag-index {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border-radius: 8px;
  background: linear-gradient(135deg, rgba(40,120,107,.14), rgba(189,93,54,.16));
  color: var(--accent);
  font-weight: 900;
  line-height: 1;
}

.resource-tag-index::before {
  content: "";
  width: 16px;
  height: 16px;
  border: 2px solid currentColor;
  border-radius: 50%;
  box-shadow: 0 0 0 5px rgba(40, 120, 107, .08);
}

.resource-tag:nth-child(2n) .resource-tag-index::before {
  border-radius: 4px;
  transform: rotate(45deg);
}

.resource-tag:nth-child(3n) .resource-tag-index::before {
  width: 0;
  height: 0;
  border-width: 0 9px 16px;
  border-style: solid;
  border-color: transparent transparent currentColor;
  border-radius: 0;
  box-shadow: none;
}

.resource-tag:nth-child(4n) .resource-tag-index::before {
  width: 18px;
  height: 10px;
  border-radius: 999px;
}

.resource-tag:nth-child(5n) .resource-tag-index::before {
  width: 18px;
  height: 18px;
  border-radius: 4px;
  box-shadow: inset 0 0 0 4px rgba(40, 120, 107, .12);
}

.resource-tag strong,
.resource-tag em,
.resource-tag small {
  display: block;
}

.resource-tag strong {
  margin-bottom: 5px;
  font-size: 1rem;
}

.resource-tag em {
  color: var(--muted);
  font-size: 13px;
  font-style: normal;
  line-height: 1.55;
}

.resource-tag small {
  grid-column: 2;
  align-self: end;
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
}

.resource-modal {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 28px;
}

.resource-modal.is-open {
  display: flex;
}

.resource-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(16, 22, 19, .46);
  backdrop-filter: blur(12px);
}

.resource-dialog {
  position: relative;
  width: min(1180px, 100%);
  max-height: min(82vh, 820px);
  overflow: auto;
  padding: 22px;
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background: var(--panel-strong);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
}

.resource-close {
  position: sticky;
  top: 0;
  z-index: 2;
  margin-left: auto;
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel-hover);
  color: var(--text);
  font-size: 26px;
  line-height: 1;
  cursor: var(--paw-cursor);
}

.resource-close:hover,
.resource-close:focus-visible {
  border-color: rgba(1,205,253,.38);
  background: var(--panel-strong);
}

.resource-panel {
  display: none;
}

.resource-panel.is-active {
  display: block;
}

.resource-panel-head {
  margin-bottom: 16px;
}

.resource-panel-head h2 {
  margin: 0 0 6px;
  font-size: clamp(24px, 4vw, 40px);
}

.resource-panel-head p:last-child {
  margin: 0;
  color: var(--muted);
}

.resource-link-list {
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.tools-page .module-intro {
  margin-bottom: 24px;
}

.tools-grid {
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  align-items: start;
}

.module-card {
  padding: 20px;
}

.tool-card {
  min-height: 0;
}

.module-card-head {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 14px;
  align-items: start;
  margin-bottom: 16px;
}

.module-card h2,
.game-card h2 {
  margin: 0 0 6px;
}

.module-card p,
.game-card p {
  color: var(--muted);
  font-size: 14px;
}

.module-icon {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(40,120,107,.14), rgba(189,93,54,.16));
  color: var(--accent);
  font-weight: 900;
}

.link-list {
  display: grid;
  gap: 10px;
}

.link-item {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: rgba(255,255,255,.52);
  color: var(--text);
  transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
}

.link-item:hover,
.link-item:focus-visible {
  transform: translateX(6px);
  border-color: rgba(1,205,253,.34);
  background: rgba(255,255,255,.78);
  box-shadow: 0 14px 36px rgba(44,42,35,.12), 0 0 24px rgba(255,113,206,.1);
}

.tool-card .link-item {
  min-height: 74px;
  align-items: flex-start;
}

.tool-more {
  position: relative;
  z-index: 1;
}

.tool-more summary {
  min-height: 42px;
  display: grid;
  place-items: center;
  border: 1px dashed rgba(40,120,107,.24);
  border-radius: var(--radius);
  background: rgba(255,255,255,.42);
  color: var(--accent);
  font-size: 13px;
  font-weight: 800;
  list-style: none;
  cursor: var(--paw-cursor);
  transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
}

.tool-more summary::-webkit-details-marker {
  display: none;
}

.tool-more summary:hover,
.tool-more[open] summary {
  transform: translateY(-2px);
  border-color: rgba(1,205,253,.42);
  background: rgba(255,255,255,.78);
  box-shadow: 0 12px 30px rgba(44,42,35,.1), 0 0 20px rgba(1,205,253,.12);
}

.tool-more .link-list {
  margin-top: 10px;
}

.link-item strong,
.link-item em {
  display: block;
}

.link-item em {
  margin-top: 2px;
  color: var(--muted);
  font-size: 13px;
  font-style: normal;
}

.link-item small,
.game-status {
  white-space: nowrap;
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
}

.game-card {
  min-height: 310px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.game-cover {
  height: 112px;
  display: grid;
  place-items: center;
  margin: -4px -4px 18px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.34);
  border-radius: var(--radius);
  background:
    radial-gradient(180px circle at 24% 18%, rgba(255,255,255,.68), transparent 34%),
    linear-gradient(135deg, rgba(40,120,107,.18), rgba(1,205,253,.18) 48%, rgba(255,113,206,.14));
}

.game-cover span {
  display: block;
  max-width: 100%;
  padding: 0 10px;
  color: currentColor;
  font-size: clamp(26px, 6vw, 46px);
  font-weight: 950;
  line-height: 1;
  text-align: center;
  overflow-wrap: anywhere;
}

.game-sections {
  display: grid;
  gap: 28px;
}

.game-section {
  position: relative;
}

.game-section-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 12px;
  margin: 0 0 12px;
}

.game-section-head .eyebrow {
  margin: 0;
}

.game-section-head span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
}

.game-card-top {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  margin-bottom: 12px;
}

.game-mood {
  position: relative;
  z-index: 2;
  white-space: nowrap;
  color: var(--accent);
  font-size: 12px;
  font-weight: 800;
}

.game-card[data-game-slug="server-survival"] {
  background:
    linear-gradient(135deg, rgba(10,22,25,.94), rgba(18,38,35,.86)),
    var(--surface);
  color: #f7fbf4;
}

.game-card[data-game-slug="server-survival"] .game-cover {
  background:
    linear-gradient(90deg, rgba(141,242,229,.32) 1px, transparent 1px),
    linear-gradient(rgba(141,242,229,.22) 1px, transparent 1px),
    radial-gradient(220px circle at 72% 28%, rgba(1,205,253,.32), transparent 52%),
    linear-gradient(135deg, rgba(4,18,21,.98), rgba(21,54,48,.86));
  background-size: 22px 22px, 22px 22px, auto, auto;
}

.game-card[data-game-slug="server-survival"] h2,
.game-card[data-game-slug="server-survival"] p,
.game-card[data-game-slug="server-survival"] .game-mood {
  color: #f7fbf4;
}

.game-card[data-game-slug="vimmaster"] {
  background:
    linear-gradient(135deg, rgba(24,22,42,.94), rgba(34,27,52,.86)),
    var(--surface);
  color: #f7fbf4;
}

.game-card[data-game-slug="vimmaster"] .game-cover {
  background:
    repeating-linear-gradient(0deg, rgba(255,255,255,.08) 0 1px, transparent 1px 9px),
    radial-gradient(220px circle at 18% 20%, rgba(143,101,255,.38), transparent 52%),
    linear-gradient(135deg, rgba(21,18,38,.98), rgba(54,31,68,.86));
}

.game-card[data-game-slug="vimmaster"] h2,
.game-card[data-game-slug="vimmaster"] p,
.game-card[data-game-slug="vimmaster"] .game-mood {
  color: #f7fbf4;
}

.game-card[data-game-slug="minesweeper"] .game-cover {
  background:
    linear-gradient(90deg, rgba(23,32,27,.15) 1px, transparent 1px),
    linear-gradient(rgba(23,32,27,.15) 1px, transparent 1px),
    linear-gradient(135deg, rgba(255,247,201,.72), rgba(199,245,220,.54));
  background-size: 22px 22px, 22px 22px, auto;
}

.game-card[data-game-slug="dino"] .game-cover {
  background:
    linear-gradient(0deg, rgba(40,120,107,.28) 0 4px, transparent 4px),
    radial-gradient(120px circle at 72% 24%, rgba(255,247,201,.88), transparent 36%),
    linear-gradient(135deg, rgba(237,248,244,.96), rgba(255,242,251,.82));
}

.game-card[data-game-slug="memory"] .game-cover {
  background:
    radial-gradient(circle at 25% 28%, rgba(255,247,201,.78) 0 14px, transparent 15px),
    radial-gradient(circle at 72% 62%, rgba(143,101,255,.28) 0 18px, transparent 19px),
    linear-gradient(135deg, rgba(255,242,251,.9), rgba(237,248,244,.86));
}

.game-play-page {
  width: min(1080px, calc(100% - 32px));
  margin: 0 auto;
  padding: 40px 0 90px;
}

.game-shell {
  display: grid;
  grid-template-columns: minmax(240px, 0.9fr) minmax(300px, 1.1fr);
  gap: 22px;
  align-items: stretch;
}

.game-shell-wide {
  grid-template-columns: minmax(260px, .78fr) minmax(420px, 1.22fr);
}

.game-panel,
.board-wrap {
  border: 1px solid rgba(255,255,255,.72);
  border-radius: var(--radius);
  background: rgba(255,255,255,.72);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
  padding: 22px;
}

.game-panel h1 {
  margin: 0 0 10px;
  font-size: clamp(44px, 8vw, 92px);
}

.score-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin: 22px 0;
}

.score-row-three {
  grid-template-columns: repeat(3, 1fr);
}

.score-row div {
  padding: 12px;
  border-radius: var(--radius);
  background: rgba(40,120,107,.1);
  border: 1px solid rgba(40,120,107,.14);
}

.score-row span,
.score-row strong {
  display: block;
}

.score-row span {
  color: var(--muted);
  font-size: 12px;
  font-weight: 800;
}

.score-row strong {
  margin-top: 4px;
  font-size: 26px;
  line-height: 1;
}

.game-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.board-wrap {
  display: grid;
  justify-items: center;
  align-content: center;
}

.mine-wrap,
.dino-wrap,
.memory-wrap {
  min-height: 520px;
}

.board-2048 {
  width: min(74vw, 460px);
  aspect-ratio: 1;
  display: grid;
  grid-template-columns: repeat(var(--board-size), 1fr);
  gap: 10px;
  padding: 10px;
  border-radius: var(--radius);
  background: rgba(23, 32, 27, .12);
  touch-action: none;
  outline: none;
}

.board-2048:focus-visible {
  box-shadow: 0 0 0 3px rgba(40,120,107,.24);
}

.tile-2048 {
  min-width: 0;
  min-height: 0;
  display: grid;
  place-items: center;
  border-radius: 6px;
  background: rgba(255,255,255,.48);
  color: var(--text);
  font-size: clamp(18px, 6vw, 42px);
  font-weight: 900;
  line-height: 1;
  transition: transform .12s ease, background .12s ease, color .12s ease;
  user-select: none;
}

.tile-2048[data-value="empty"] {
  color: transparent;
}

.tile-2048[data-value="2"] { background: #f8efe2; }
.tile-2048[data-value="4"] { background: #f2dfc8; }
.tile-2048[data-value="8"] { background: #dfb079; color: #fffaf2; }
.tile-2048[data-value="16"] { background: #d89561; color: #fffaf2; }
.tile-2048[data-value="32"] { background: #c86f4e; color: #fffaf2; }
.tile-2048[data-value="64"] { background: #bd5d36; color: #fffaf2; }
.tile-2048[data-value="128"] { background: #d8b64c; color: #17201b; font-size: clamp(17px, 5vw, 36px); }
.tile-2048[data-value="256"] { background: #bba646; color: #17201b; font-size: clamp(17px, 5vw, 36px); }
.tile-2048[data-value="512"] { background: #75a36f; color: #fffaf2; font-size: clamp(17px, 5vw, 36px); }
.tile-2048[data-value="1024"] { background: #3f8f80; color: #fffaf2; font-size: clamp(15px, 4.4vw, 31px); }
.tile-2048[data-value="2048"] { background: #28786b; color: #fffaf2; font-size: clamp(15px, 4.4vw, 31px); }

.mine-board {
  width: min(86vw, 520px);
  display: grid;
  grid-template-columns: repeat(var(--mine-size), 1fr);
  gap: 5px;
  padding: 10px;
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, rgba(23,32,27,.12), rgba(40,120,107,.08)),
    rgba(255,255,255,.44);
  touch-action: manipulation;
}

.mine-cell {
  aspect-ratio: 1;
  min-width: 0;
  border: 1px solid rgba(255,255,255,.72);
  border-radius: 6px;
  background:
    radial-gradient(circle at 28% 22%, rgba(255,255,255,.92), transparent 28%),
    linear-gradient(135deg, rgba(199,245,220,.9), rgba(237,248,244,.72));
  color: var(--text);
  font-size: clamp(13px, 3.6vw, 22px);
  font-weight: 950;
  line-height: 1;
  box-shadow: inset 0 -2px 0 rgba(23,32,27,.08);
  user-select: none;
}

.mine-cell[data-state="open"] {
  background: rgba(255,255,255,.58);
  box-shadow: inset 0 0 0 1px rgba(23,32,27,.04);
}

.mine-cell[data-state="flag"] {
  background: linear-gradient(135deg, rgba(255,247,201,.94), rgba(216,182,76,.42));
  color: #bd5d36;
}

.mine-cell[data-nearby="1"] { color: #28786b; }
.mine-cell[data-nearby="2"] { color: #1f6fc1; }
.mine-cell[data-nearby="3"] { color: #bd5d36; }
.mine-cell[data-nearby="4"],
.mine-cell[data-nearby="5"],
.mine-cell[data-nearby="6"],
.mine-cell[data-nearby="7"],
.mine-cell[data-nearby="8"] { color: #8f65ff; }

.dino-canvas {
  width: min(100%, 920px);
  aspect-ratio: 23 / 9;
  min-height: 260px;
  display: block;
  border: 1px solid rgba(255,255,255,.72);
  border-radius: var(--radius);
  background: #f8f6ef;
  box-shadow: inset 0 0 0 1px rgba(40,120,107,.08);
  touch-action: manipulation;
}

.memory-board {
  width: min(88vw, 620px);
  display: grid;
  grid-template-columns: repeat(var(--memory-cols), 1fr);
  gap: 10px;
  padding: 10px;
  border-radius: var(--radius);
  background:
    radial-gradient(420px circle at 15% 0%, rgba(255,247,201,.34), transparent 58%),
    linear-gradient(135deg, rgba(40,120,107,.1), rgba(143,101,255,.1));
}

.memory-card {
  aspect-ratio: 1;
  min-width: 0;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.72);
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, rgba(24,22,42,.92), rgba(40,120,107,.72)),
    radial-gradient(circle at 28% 24%, rgba(255,255,255,.5), transparent 30%);
  color: #fffaf2;
  font-size: clamp(20px, 5vw, 40px);
  font-weight: 950;
  line-height: 1;
  box-shadow: 0 12px 28px rgba(44,42,35,.12), inset 0 0 0 1px rgba(255,255,255,.08);
  transform-style: preserve-3d;
  transition: transform .18s ease, background .18s ease, opacity .18s ease;
}

.memory-card[data-state="closed"]::before {
  content: "?";
  color: rgba(255,250,242,.76);
}

.memory-card[data-state="open"],
.memory-card[data-state="matched"] {
  background:
    radial-gradient(circle at 32% 22%, rgba(255,255,255,.86), transparent 28%),
    linear-gradient(135deg, rgba(255,247,201,.94), rgba(255,242,251,.84));
