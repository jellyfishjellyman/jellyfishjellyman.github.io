}

.post-content h2,
.post-content h3 {
  scroll-margin-top: 96px;
}

.post-neighbors {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
  margin: 34px 0 10px;
}

.post-neighbors a {
  display: grid;
  gap: 5px;
  min-height: 96px;
  padding: 14px;
  border: 1px solid rgba(40,120,107,.14);
  border-radius: var(--radius);
  background:
    linear-gradient(180deg, rgba(255,255,255,.72), rgba(255,255,255,.46)),
    radial-gradient(260px circle at 10% 0%, rgba(1,205,253,.12), transparent 62%);
