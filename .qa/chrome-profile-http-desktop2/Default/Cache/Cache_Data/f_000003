.post-card,
.module-card,
.game-card,
.feature-card,
.resource-tag,
.link-item {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  background: var(--surface);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
  transform: perspective(900px) rotateX(var(--tilt-y, 0deg)) rotateY(var(--tilt-x, 0deg)) translateY(0);
  transform-style: preserve-3d;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease, background .24s ease;
}

.post-card::before,
.module-card::before,
.game-card::before,
.feature-card::before,
.resource-tag::before,
.link-item::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  background:
    radial-gradient(320px circle at var(--card-x, 50%) var(--card-y, 50%), rgba(255,255,255,.92), transparent 34%),
    linear-gradient(135deg, rgba(255,113,206,.18), transparent 36%, rgba(1,205,253,.16));
  transition: opacity .22s ease;
}

.post-card::after,
.module-card::after,
.game-card::after,
.feature-card::after,
.resource-tag::after,
.link-item::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  opacity: 0;
  border: 1px solid transparent;
  background: linear-gradient(135deg, rgba(255,113,206,.78), rgba(1,205,253,.7), rgba(216,182,76,.5)) border-box;
  mask: linear-gradient(#000 0 0) padding-box, linear-gradient(#000 0 0);
  mask-composite: exclude;
  transition: opacity .22s ease;
}

.post-card:hover,
.module-card:hover,
.game-card:hover,
.feature-card:hover {
  transform: perspective(900px) rotateX(var(--tilt-y, 0deg)) rotateY(var(--tilt-x, 0deg)) translateY(-7px) scale(1.012);
  border-color: rgba(1, 205, 253, .34);
  background: var(--panel-hover);
  box-shadow:
    var(--shadow),
    0 0 0 1px var(--panel-border-soft),
