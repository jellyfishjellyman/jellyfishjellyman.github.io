}

.post-card:hover::before,
.post-card:hover::after,
.module-card:hover::before,
.module-card:hover::after,
.game-card:hover::before,
.game-card:hover::after,
.feature-card:hover::before,
.feature-card:hover::after,
.resource-tag:hover::before,
.resource-tag:hover::after,
.resource-tag:focus-visible::before,
.resource-tag:focus-visible::after,
.resource-tag.is-active::before,
.resource-tag.is-active::after,
.link-item:hover::before,
.link-item:hover::after,
.link-item:focus-visible::before,
.link-item:focus-visible::after {
