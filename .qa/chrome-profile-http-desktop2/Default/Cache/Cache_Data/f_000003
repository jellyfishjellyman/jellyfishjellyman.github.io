:root {
  --bg: #f6f4ee;
  --surface: rgba(255, 255, 255, 0.78);
  --surface-strong: rgba(255, 255, 255, 0.94);
  --text: #17201b;
  --muted: #66736d;
  --line: rgba(23, 32, 27, 0.12);
  --subtle-text: rgba(23, 32, 27, .82);
  --body-bg:
    radial-gradient(640px circle at var(--mouse-x, 50%) var(--mouse-y, 12%), rgba(255, 247, 201, 0.24), transparent 42%),
    radial-gradient(820px circle at calc(100% - var(--mouse-x, 50%)) 26%, rgba(216, 204, 255, 0.24), transparent 44%),
    radial-gradient(760px circle at 18% 74%, rgba(199, 245, 220, 0.38), transparent 48%),
    radial-gradient(900px circle at 85% 80%, rgba(255, 113, 206, 0.13), transparent 48%),
    linear-gradient(135deg, #f8f6ef 0%, #edf8f4 43%, #fff2fb 100%);
  --page-wash: #f6f4ee;
  --panel: rgba(255, 250, 242, .76);
  --panel-strong: rgba(255, 255, 255, .86);
  --panel-soft: rgba(255, 255, 255, .52);
  --panel-hover: rgba(255, 255, 255, .84);
  --panel-border: rgba(255, 255, 255, .7);
  --panel-border-soft: rgba(255, 255, 255, .58);
  --chip-bg: rgba(40, 120, 107, .1);
  --chip-border: rgba(40, 120, 107, .16);
  --code-inline-bg: rgba(23, 32, 27, .07);
  --field-bg: rgba(255, 255, 255, .48);
  --dark-panel: #111814;
  --dark-panel-text: #eef4ef;
  --hero-contrast: #f7fbf4;
  --hero-contrast-muted: rgba(247, 251, 244, .72);
  --accent: #28786b;
  --accent-2: #bd5d36;
  --accent-3: #d8b64c;
  --vapor-pink: #ff71ce;
  --vapor-cyan: #01cdfd;
  --vapor-violet: #8f65ff;
  --dream-mint: #c7f5dc;
  --dream-lilac: #d8ccff;
  --dream-moon: #fff7c9;
  --cursor-hue: 174deg;
  --shadow: 0 24px 80px rgba(44, 42, 35, 0.15);
  --shadow-soft: 0 12px 36px rgba(44, 42, 35, .1);
  --glow: 0 0 34px rgba(1,205,253,.16);
  --focus-ring: 0 0 0 3px color-mix(in srgb, var(--vapor-cyan) 32%, transparent);
  --radius: 8px;
  --paw-cursor: url("data:image/svg+xml,%3Csvg width='32' height='32' viewBox='0 0 32 32' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%2317201b' stroke='%23fffaf2' stroke-width='1.6'%3E%3Cellipse cx='11' cy='9' rx='3.2' ry='4.2' transform='rotate(-20 11 9)'/%3E%3Cellipse cx='19' cy='8' rx='3.2' ry='4.2' transform='rotate(15 19 8)'/%3E%3Cellipse cx='7' cy='16' rx='3' ry='4' transform='rotate(-35 7 16)'/%3E%3Cellipse cx='23' cy='15' rx='3' ry='4' transform='rotate(32 23 15)'/%3E%3Cpath d='M10 22c.8-4 3-6 6-6s5.3 2 6 6c.5 2.8-1 4.7-4.3 4.4-1.1-.1-2.4-.1-3.5 0C11 26.7 9.5 24.8 10 22Z'/%3E%3C/g%3E%3C/svg%3E") 9 8, auto;
}

:root[data-theme="night"] {
  --bg: #101412;
  --surface: rgba(24, 31, 28, 0.78);
  --surface-strong: rgba(24, 31, 28, 0.94);
  --text: #eef4ef;
  --muted: #a9b8b1;
  --line: rgba(238, 244, 239, 0.14);
  --subtle-text: rgba(238, 244, 239, .78);
  --body-bg:
    radial-gradient(640px circle at var(--mouse-x, 50%) var(--mouse-y, 12%), rgba(117, 223, 207, 0.16), transparent 42%),
    radial-gradient(820px circle at calc(100% - var(--mouse-x, 50%)) 26%, rgba(143, 101, 255, 0.2), transparent 44%),
    radial-gradient(900px circle at 82% 74%, rgba(255, 113, 206, 0.12), transparent 48%),
    linear-gradient(135deg, #09100f 0%, #14201d 46%, #19152a 100%);
  --page-wash: #101412;
  --panel: rgba(16, 23, 21, .78);
  --panel-strong: rgba(24, 31, 28, .94);
  --panel-soft: rgba(255, 255, 255, .08);
  --panel-hover: rgba(30, 39, 36, .9);
  --panel-border: rgba(255, 255, 255, .16);
  --panel-border-soft: rgba(255, 255, 255, .12);
  --chip-bg: rgba(117, 223, 207, .1);
  --chip-border: rgba(117, 223, 207, .22);
  --code-inline-bg: rgba(255, 255, 255, .08);
  --field-bg: rgba(255, 255, 255, .08);
  --dark-panel: #0c1212;
  --dark-panel-text: #eef4ef;
  --hero-contrast: #f7fbf4;
  --hero-contrast-muted: rgba(247, 251, 244, .72);
  --accent: #75dfcf;
  --accent-2: #ff9f7a;
  --accent-3: #ead06d;
  --shadow: 0 24px 80px rgba(0, 0, 0, 0.3);
  --shadow-soft: 0 12px 36px rgba(0, 0, 0, .22);
  --glow: 0 0 34px rgba(117,223,207,.16);
  --focus-ring: 0 0 0 3px color-mix(in srgb, var(--accent) 34%, transparent);
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

html,
body {
  min-height: 100%;
  color: var(--text);
  background: var(--body-bg);
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  cursor: var(--paw-cursor);
  transition: background-color .35s ease, color .35s ease;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans CJK SC", "Helvetica Neue", Arial, sans-serif;
  line-height: 1.8;
  font-size: 17px;
  overflow-x: hidden;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -2;
  background-image:
    linear-gradient(115deg, transparent 0 62%, rgba(255,113,206,.12) 62% 63%, transparent 63%),
    radial-gradient(circle at 20% 12%, rgba(255,247,201,.42) 0 2px, transparent 3px),
    radial-gradient(circle at 72% 26%, rgba(216,204,255,.48) 0 1px, transparent 3px),
    linear-gradient(rgba(23, 32, 27, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(23, 32, 27, 0.035) 1px, transparent 1px);
  background-size: 120px 120px, 180px 180px, 240px 240px, 42px 42px, 42px 42px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,.75), rgba(0,0,0,.12));
}

body::after {
  content: "";
  position: fixed;
  width: 290px;
  height: 290px;
  left: calc(var(--mouse-x, 50%) - 145px);
  top: calc(var(--mouse-y, 50%) - 145px);
  pointer-events: none;
  z-index: -1;
  border-radius: 999px;
  background:
    radial-gradient(circle, rgba(255,255,255,.8) 0 2px, transparent 3px),
    radial-gradient(circle, rgba(1,205,253,.18), rgba(255,113,206,.12) 34%, transparent 64%);
  mix-blend-mode: soft-light;
  opacity: 0;
  transform: translate3d(0, 0, 0);
  transition: left .14s ease-out, top .14s ease-out, opacity .18s ease;
}

body.has-pointer::after {
  opacity: .72;
}

body.is-card-hovered::after {
  opacity: .95;
  mix-blend-mode: screen;
}

body.theme-is-switching::before {
  z-index: 2300;
  opacity: 1;
  background:
    radial-gradient(circle at var(--switch-x, 50%) var(--switch-y, 42%), rgba(255,247,201,.98) 0 34px, rgba(255,183,90,.52) 35px 74px, transparent 75px),
    linear-gradient(180deg, rgba(255,247,201,.24), rgba(9,16,15,.42));
  mask-image: none;
  animation: themeCurtain .72s cubic-bezier(.16,1,.3,1) forwards;
}

body.theme-switch-to-day::before {
  background:
    radial-gradient(circle at var(--switch-x, 50%) var(--switch-y, 42%), rgba(255,247,201,.98) 0 38px, rgba(255,183,90,.62) 39px 86px, transparent 87px),
    linear-gradient(180deg, rgba(255,247,201,.4), rgba(255,250,242,.18));
}

body.theme-switch-to-night::before {
  background:
    radial-gradient(circle at var(--switch-x, 50%) var(--switch-y, 58%), rgba(117,223,207,.72) 0 28px, rgba(143,101,255,.38) 29px 72px, transparent 73px),
    linear-gradient(180deg, rgba(11,16,22,.2), rgba(5,8,12,.82));
}

@keyframes themeCurtain {
  0% {
    clip-path: circle(0 at var(--switch-x, 50%) var(--switch-y, 50%));
    opacity: 0;
  }
  42% {
    clip-path: circle(36vmax at var(--switch-x, 50%) var(--switch-y, 50%));
    opacity: .92;
  }
  100% {
    clip-path: circle(128vmax at var(--switch-x, 50%) var(--switch-y, 50%));
    opacity: 0;
  }
}

.reading-progress {
  position: fixed;
  left: 0;
  top: 0;
  z-index: 2000;
  width: 100%;
  height: 3px;
  transform: scaleX(0);
  transform-origin: left;
  background: linear-gradient(90deg, #31d6c9, #e95d89, #d8b64c);
  box-shadow: 0 0 18px rgba(49, 214, 201, .45);
  pointer-events: none;
}

.cursor-trail {
  position: fixed;
  left: 0;
  top: 0;
  width: 12px;
  height: 12px;
  border: 1px solid rgba(1,205,253,.54);
  border-radius: 50%;
  pointer-events: none;
  z-index: 999;
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(.7);
  transition: opacity .2s ease;
  box-shadow: 0 0 18px rgba(255,113,206,.28);
}

body.has-pointer .cursor-trail {
  opacity: .55;
}

.pointer-spark.is-game-spark {
  width: 13px;
  height: 13px;
  border-radius: 2px;
  background:
    linear-gradient(135deg, rgba(141,242,229,.95), rgba(255,113,206,.7)),
    radial-gradient(circle, rgba(255,255,255,.9), transparent 62%);
  box-shadow: 0 0 18px rgba(141,242,229,.34), 0 0 30px rgba(143,101,255,.26);
  rotate: 45deg;
}

.pointer-spark,
.pointer-ripple {
  position: fixed;
  left: 0;
  top: 0;
  pointer-events: none;
  z-index: 1600;
}

.pointer-spark {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background:
    radial-gradient(circle at 35% 35%, rgba(255,255,255,.95), rgba(255,113,206,.72) 42%, rgba(1,205,253,.18) 72%, transparent 74%);
  box-shadow: 0 0 16px rgba(1,205,253,.22), 0 0 22px rgba(255,113,206,.16);
  transform: translate3d(-50%, -50%, 0) scale(1);
  animation: pointerSpark .62s ease-out forwards;
}

.pointer-ripple {
  width: 34px;
  height: 30px;
  background:
    radial-gradient(ellipse at 50% 68%, rgba(40,120,107,.72) 0 31%, transparent 33%),
    radial-gradient(ellipse at 23% 28%, rgba(40,120,107,.7) 0 13%, transparent 15%),
    radial-gradient(ellipse at 42% 17%, rgba(40,120,107,.7) 0 12%, transparent 14%),
    radial-gradient(ellipse at 62% 17%, rgba(40,120,107,.7) 0 12%, transparent 14%),
    radial-gradient(ellipse at 81% 28%, rgba(40,120,107,.7) 0 13%, transparent 15%);
  filter: drop-shadow(0 0 10px rgba(1,205,253,.24));
  transform: translate3d(-50%, -50%, 0) scale(.55);
  animation: pointerRipple .46s ease-out forwards;
}

@keyframes pointerSpark {
  to {
    opacity: 0;
    transform: translate3d(calc(-50% + var(--spark-x, 0px)), calc(-50% + var(--spark-y, 0px)), 0) scale(.18);
  }
}

@keyframes pointerRipple {
  to {
    opacity: 0;
    transform: translate3d(-50%, -50%, 0) scale(1.9) rotate(-8deg);
  }
}

.dream-noise {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  opacity: .08;
  background-image:
    repeating-linear-gradient(0deg, rgba(23,32,27,.18) 0 1px, transparent 1px 4px),
    radial-gradient(circle at 18% 28%, rgba(255,255,255,.9), transparent 16%),
    radial-gradient(circle at 86% 12%, rgba(255,113,206,.56), transparent 14%);
  filter: blur(.2px);
}

.vapor-grid {
  position: fixed;
  left: 50%;
  bottom: -12vh;
  z-index: -1;
  width: min(960px, 120vw);
  height: 34vh;
  pointer-events: none;
  opacity: .28;
  transform: translateX(-50%) perspective(560px) rotateX(66deg);
  transform-origin: bottom;
  background-image:
    linear-gradient(rgba(1,205,253,.34) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,113,206,.3) 1px, transparent 1px);
  background-size: 44px 44px;
  mask-image: linear-gradient(to top, rgba(0,0,0,.8), transparent 86%);
}

@keyframes vaporDrift {
  from { background-position: 0 0, 0 0, 0 0; }
  to { background-position: 120px 120px, 180px 120px, -160px 240px, 42px 42px, -42px 42px; }
}

a,
button,
[role="button"] {
  cursor: var(--paw-cursor);
}

:focus-visible {
  outline: 2px solid color-mix(in srgb, var(--accent) 68%, transparent);
  outline-offset: 3px;
}

button,
.primary-button,
.ghost-button,
.theme-toggle,
.resource-tag,
.link-item,
#backToTop,
#musicToggle {
  -webkit-tap-highlight-color: transparent;
}

button:active,
.primary-button:active,
.ghost-button:active,
.theme-toggle:active,
.resource-tag:active,
.link-item:active,
#backToTop:active,
#musicToggle:active {
  transform: translateY(1px) scale(.985);
}

input,
textarea,
select,
[contenteditable="true"] {
  cursor: auto;
}

body.has-resource-modal {
  overflow: hidden;
}

:root[data-theme="night"] html,
:root[data-theme="night"] body,
:root[data-theme="night"] {
  color-scheme: dark;
}

a {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid color-mix(in srgb, var(--accent) 34%, transparent);
  transition: color .18s ease, border-color .18s ease, opacity .18s ease, transform .18s ease;
}

a:hover {
  color: var(--accent);
  border-bottom-color: color-mix(in srgb, var(--accent) 70%, transparent);
}

p {
  margin: 0.9em 0;
}

ul,
ol {
  margin: 0.9em 0 0.9em 1.2em;
}

li {
  margin: 0.35em 0;
}

h1,
h2,
h3 {
  line-height: 1.2;
  letter-spacing: 0;
}

h1 {
  font-size: 2.1rem;
}

h2 {
  font-size: 1.55rem;
}

h3 {
  font-size: 1.22rem;
}

main.pb7 {
  padding-bottom: 88px;
}

.site-header {
  position: relative;
  z-index: 20;
}

.site-nav {
  position: sticky;
  top: 14px;
  z-index: 100;
  width: min(1120px, calc(100% - 28px));
  margin: 14px auto 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 10px 12px;
  border: 1px solid var(--panel-border-soft);
  border-radius: var(--radius);
  background: var(--panel);
  backdrop-filter: blur(18px);
  box-shadow: var(--shadow-soft);
  transition: width .24s ease, padding .24s ease, background .24s ease, box-shadow .24s ease, border-color .24s ease;
}

body.is-scrolled .site-nav {
  width: min(1040px, calc(100% - 28px));
  padding: 8px 10px;
  border-color: var(--panel-border);
  background: var(--panel-strong);
  box-shadow: var(--shadow), 0 0 0 1px color-mix(in srgb, var(--accent) 10%, transparent);
}

.site-brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--text);
  border: 0;
  font-weight: 700;
  white-space: nowrap;
}

.site-brand span {
  position: relative;
}

.site-brand span::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -6px;
  height: 1px;
  background: linear-gradient(90deg, rgba(49,214,201,.7), transparent);
  opacity: .72;
}

.site-brand img {
  width: 36px;
  height: 36px;
  object-fit: cover;
  border-radius: 50%;
  box-shadow: 0 6px 18px rgba(23, 32, 27, .16);
}

.site-menu {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 4px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.site-menu a {
  display: inline-flex;
  align-items: center;
  position: relative;
  min-height: 34px;
  padding: 6px 12px;
  border: 0;
  border-radius: var(--radius);
  color: var(--text);
  font-size: 15px;
  line-height: 1;
}

.site-menu a:hover,
.site-menu a.is-active {
  background: var(--chip-bg);
  color: var(--accent);
}

.theme-toggle {
  flex: 0 0 auto;
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  position: relative;
  overflow: hidden;
  border: 1px solid var(--chip-border);
  border-radius: var(--radius);
  background: var(--panel-soft);
  color: var(--text);
  font-size: 17px;
  line-height: 1;
  cursor: var(--paw-cursor);
  transition: background .28s ease, border-color .28s ease, box-shadow .28s ease;
}

.theme-toggle::after {
  content: "";
  position: absolute;
  inset: 4px;
  border: 1px solid color-mix(in srgb, var(--panel-border) 70%, transparent);
  border-radius: calc(var(--radius) - 2px);
  opacity: .62;
  pointer-events: none;
}

.theme-toggle::before {
  content: "";
  position: absolute;
  inset: 7px;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff7c9, #d8b64c);
  box-shadow: 0 0 22px rgba(216,182,76,.42);
  transform: translateY(0);
  transition: transform .42s ease, opacity .42s ease, background .42s ease, box-shadow .42s ease;
}

.theme-toggle span {
  position: relative;
  z-index: 1;
  color: var(--text);
  font-size: 0;
}

.theme-toggle span::before {
  content: "";
  display: block;
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: var(--text);
  box-shadow: -5px -2px 0 1px var(--panel-strong);
  opacity: 0;
  transition: opacity .3s ease, background .3s ease, box-shadow .3s ease;
}

.theme-toggle:hover,
.theme-toggle:focus-visible {
  border-color: color-mix(in srgb, var(--vapor-cyan) 42%, transparent);
  background: var(--panel-hover);
  box-shadow: var(--glow);
}

:root[data-theme="night"] .theme-toggle::before {
  background: linear-gradient(135deg, #75dfcf, #8f65ff);
  box-shadow: 0 0 24px rgba(117,223,207,.34);
  transform: translate(7px, 7px) scale(.72);
  opacity: .36;
}

:root[data-theme="night"] .theme-toggle span::before {
  opacity: 1;
}

.site-menu a.is-active::after {
  content: "";
  position: absolute;
  left: 12px;
  right: 12px;
  bottom: 4px;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--accent), var(--vapor-cyan));
  opacity: .85;
}

.page-hero {
  width: min(940px, calc(100% - 32px));
  margin: 78px auto 34px;
  text-align: center;
}

.page-hero h1 {
  margin: 0;
  font-size: clamp(34px, 7vw, 76px);
}

.page-hero p:not(.eyebrow) {
  max-width: 680px;
  margin: 14px auto 0;
  color: var(--muted);
}

.eyebrow {
  margin: 0 0 10px;
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
}

.hero {
  min-height: 100svh;
  position: relative;
  width: 100%;
  display: grid;
  place-items: center;
  padding: 92px 18px 96px;
  margin-top: -64px;
  overflow: hidden;
  background: url("/images/hero-optimized.jpg") center/cover no-repeat;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(520px circle at var(--mouse-x, 55%) var(--mouse-y, 42%), rgba(255,255,255,.2), transparent 42%),
    linear-gradient(180deg, rgba(12, 19, 18, .62), rgba(12, 19, 18, .36) 52%, rgba(247, 244, 238, .18));
}

.hero-overlay {
  position: absolute;
  inset: auto 0 0;
  height: 42%;
  background: linear-gradient(180deg, transparent, rgba(247, 244, 238, .92));
}

.hero-inner {
  position: relative;
  width: min(980px, 100%);
  color: #fffaf2;
  text-align: center;
}

.hero-title {
  margin: 0 0 14px;
  font-size: clamp(44px, 8vw, 94px);
  line-height: 1.02;
  text-shadow: 0 18px 70px rgba(0,0,0,.52);
}

.hero-sub {
  margin: 0 auto;
  max-width: 780px;
  font-size: clamp(16px, 2.2vw, 23px);
  color: rgba(255,250,242,.92);
  text-shadow: 0 12px 44px rgba(0,0,0,.5);
}

.hero-actions {
  margin-top: 28px;
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.primary-button,
.ghost-button,
.hero-hint {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 10px 16px;
  border-radius: var(--radius);
  border: 1px solid var(--panel-border-soft);
  background: color-mix(in srgb, var(--panel) 74%, transparent);
  color: inherit;
  backdrop-filter: blur(12px);
  box-shadow: 0 12px 34px rgba(0,0,0,.14);
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease, color .18s ease;
}

.primary-button {
  background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--vapor-cyan) 46%, var(--accent)));
  color: var(--bg);
  border-color: transparent;
  font-weight: 800;
}

.primary-button:hover,
.primary-button:focus-visible,
.ghost-button:hover,
.ghost-button:focus-visible,
.hero-hint:hover,
.hero-hint:focus-visible {
  border-color: color-mix(in srgb, var(--vapor-cyan) 42%, var(--panel-border));
  background: var(--panel-hover);
  box-shadow: var(--shadow-soft), var(--glow);
}

.primary-button:hover,
.primary-button:focus-visible {
  color: var(--text);
}

.hero-hint {
  margin-top: 22px;
  gap: 10px;
  font-size: 14px;
}

.hero-hint::after {
  content: "";
  width: 9px;
  height: 9px;
  border-right: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: rotate(45deg);
  animation: hintBounce 1.35s ease-in-out infinite;
}

@keyframes hintBounce {
  0%, 100% { transform: translateY(0) rotate(45deg); opacity: .82; }
  50% { transform: translateY(5px) rotate(45deg); opacity: 1; }
}

.hero-animate {
  opacity: 0;
  transform: translateY(28px);
  filter: blur(8px);
  animation: heroPop .95s cubic-bezier(.2,.9,.2,1) forwards;
}

.hero-animate.delay-1 { animation-delay: .16s; }
.hero-animate.delay-2 { animation-delay: .30s; }
.hero-animate.delay-3 { animation-delay: .44s; }

@keyframes heroPop {
  to {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

